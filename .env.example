# Contact form (MailerSend) — copy to .env for local dev, and set the same
# values in Vercel → Project → Settings → Environment Variables for production.

# API token from MailerSend (Settings → API tokens), with email-send permission.
MAILERSEND_API_KEY=

# Where contact-form messages are delivered.
CONTACT_EMAIL=ben@whitfield.dev

# The sender address. MUST be on a domain you've verified in MailerSend.
FROM_EMAIL=noreply@whitfield.dev
