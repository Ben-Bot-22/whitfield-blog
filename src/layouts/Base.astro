---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'whitfield.dev' } = Astro.props;
const siteTitle = 'whitfield.dev';
const fullTitle = title === siteTitle ? siteTitle : `${title} — ${siteTitle}`;

// Active nav state. "Blog" is really Home (the homepage hosts the blog).
const path = Astro.url.pathname;
const onHire = path.startsWith('/hire-me');
const onBlog = path === '/' || path.startsWith('/blog');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-nav-bar">
      <nav class="site-nav">
        <a href="/" class:list={[{ 'is-active': onBlog }]}>Blog</a>
        <a href="/hire-me" class:list={[{ 'is-active': onHire }]}>Hire Me</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
