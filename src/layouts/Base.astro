---
import '../styles/base.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'whitfield.dev' } = Astro.props;
const siteTitle = 'whitfield.dev';
const fullTitle = title === siteTitle ? siteTitle : `${title} — ${siteTitle}`;

// Active nav state. "Blog" is really Home (the homepage hosts the blog).
const path = Astro.url.pathname;
const onHire = path.startsWith('/hire-me');
const onHome = path === '/' || path.startsWith('/blog');

const siteOrigin = Astro.site ?? new URL('https://whitfield.dev');
const canonical = new URL(path, siteOrigin).href;
const ogImage = new URL('/og.png', siteOrigin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>

    <!-- Open Graph / Twitter — the rainbow-name card renders for shared links. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="whitfield.dev" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-nav-bar">
      <nav class="site-nav">
        <a href="/" class:list={[{ 'is-active': onHome }]}>Home</a>
        <a href="/hire-me" class:list={[{ 'is-active': onHire }]}>Hire Me</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
