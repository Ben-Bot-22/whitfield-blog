---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  image?: string;
}

const { title, description, pubDate, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <article>
    <header class="post-header animate-in">
      <a href="/" class="back-link">&larr; whitfield.dev</a>
      <span class="post-date">{formattedDate}</span>
      <h1>{title}</h1>
      {image && <img src={image} alt={title} class="hero-image" />}
    </header>
    <div class="prose animate-in" style="animation-delay: 80ms;">
      <slot />
    </div>
  </article>
</Base>
