---
export const prerender = false;

import Base from "../layouts/Base.astro";
import "../styles/contact.css";
---

<Base title="Contact" description="Get in touch with Ben Whitfield">
  <a href="/" class="back-link">&larr; whitfield.dev</a>

  <h1 class="contact-title">Get in touch</h1>

  <form id="contact-form" class="contact-form" novalidate>
    <!-- Honeypot: hidden from people, bots fill it -->
    <div class="honeypot" aria-hidden="true">
      <label for="website">Website</label>
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <div class="field">
      <label class="field-label" for="email">Your email</label>
      <input
        class="field-input"
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@example.com"
      />
    </div>

    <div class="field">
      <label class="field-label" for="message">Message</label>
      <textarea
        class="field-textarea"
        id="message"
        name="message"
        required
        minlength="10"
        maxlength="5000"
        placeholder="What's on your mind?"></textarea>
    </div>

    <button type="submit" class="contact-submit">Send message</button>

    <p id="contact-status" class="contact-status" role="status" aria-live="polite"></p>
  </form>
</Base>

<script>
  import { actions } from "astro:actions";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const status = document.getElementById("contact-status")!;
  const submitBtn = form.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement;

  function setStatus(message: string, kind: "" | "is-error" | "is-success") {
    status.textContent = message;
    status.classList.remove("is-error", "is-success");
    if (kind) status.classList.add(kind);
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    setStatus("Sending…", "");

    try {
      const { error } = await actions.contact(new FormData(form));
      if (error) {
        // Surface validation messages when present, else a generic error
        const message =
          "fields" in error && error.fields
            ? Object.values(error.fields).flat().join(" ")
            : error.message;
        setStatus(message || "Something went wrong. Please try again.", "is-error");
        return;
      }
      setStatus("Sent! Thanks — I'll get back to you soon.", "is-success");
      form.reset();
    } catch {
      setStatus("Something went wrong. Please try again.", "is-error");
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
